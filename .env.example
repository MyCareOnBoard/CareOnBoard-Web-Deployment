# Firebase Configuration
# Get these values from your Firebase Console:
# https://console.firebase.google.com/

VITE_FIREBASE_API_KEY=your-api-key-here
VITE_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your-messaging-sender-id
VITE_FIREBASE_APP_ID=your-app-id

# Firebase Auth emulator (local MFA/SMS testing — use console test phone numbers)
# VITE_USE_FIREBASE_EMULATOR=true
#
# Phone/MFA on real Firebase: open the app at http://127.0.0.1:5173 (not localhost).
# 1) Firebase → Authentication → Settings → Authorized domains → add 127.0.0.1
# 2) Google Cloud → Security → reCAPTCHA Enterprise → your Firebase key → Domains → add 127.0.0.1
#    (CAPTCHA_CHECK_FAILED "Hostname match not found" means step 2 is missing.)
# 3) Phone test numbers: Sign-in method → Phone → +16505553434 / 123456

# API Configuration
VITE_API_BASE_URL=

# Google Places API
VITE_GOOGLE_PLACES_API_KEY=your-google-places-api-key

# Mobile App Configuration
# Deep link scheme for opening the mobile app (without query parameters)
VITE_MOBILE_APP_DEEP_LINK_SCHEME=careonboardapplicant://register

# App Store URLs
VITE_MOBILE_APP_IOS_STORE_URL=https://apps.apple.com/app/6760315221
VITE_MOBILE_APP_ANDROID_STORE_URL=https://play.google.com/store/apps/details?id=com.iota.careonboardapplicant
